{
	"name": "pi-glm-image-summary",
	"version": "0.1.4",
	"type": "module",
	"description": "Pi extension that proxies media analysis through glm-4.6v for models without native image support",
	"keywords": [
		"pi-package",
		"glm",
		"image",
		"vision",
		"ai"
	],
	"author": "kaofelix",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/edxeth/pi-multi-modal.git"
	},
	"files": [
		"src"
	],
	"scripts": {
		"format": "biome format --write .",
		"lint": "biome lint .",
		"typecheck": "tsc --noEmit",
		"check": "biome check . && tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:integration": "vitest run --config vitest.integration.config.ts",
		"verify:smart-paste:direct-shell": "/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/verify-smart-paste-direct-shell.ps1",
		"verify:smart-paste:router": "node scripts/verify-wezterm-route-only.mjs"
	},
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"peerDependencies": {
		"@mariozechner/pi-ai": "*",
		"@mariozechner/pi-coding-agent": "*",
		"@mariozechner/pi-tui": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.13",
		"@mariozechner/pi-ai": "^0.51.4",
		"@mariozechner/pi-coding-agent": "^0.51.4",
		"@mariozechner/pi-tui": "^0.51.4",
		"@types/node": "^25.2.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
