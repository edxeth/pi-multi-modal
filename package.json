{
	"name": "pi-multi-modal",
	"version": "0.1.4",
	"type": "module",
	"description": "Pi extension that proxies local media analysis through a configurable backend for models without native image support",
	"keywords": [
		"pi-package",
		"multi-modal",
		"image",
		"vision",
		"ai"
	],
	"author": "kaofelix",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/edxeth/pi-multi-modal.git"
	},
	"files": [
		"src"
	],
	"scripts": {
		"format": "npx @biomejs/biome@latest format --write .",
		"lint": "npx @biomejs/biome@latest lint .",
		"knip": "npx knip@latest",
		"typecheck": "tsc --noEmit",
		"check": "npx @biomejs/biome@latest check . && tsc --noEmit",
		"verify": "npm run check && npm run knip && npm test",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:integration": "vitest run --config vitest.integration.config.ts",
		"verify:smart-paste:direct-shell": "bash scripts/verify-smart-paste-direct-shell.sh",
		"verify:smart-paste:direct-nvim": "bash scripts/verify-smart-paste-direct-nvim.sh",
		"verify:smart-paste:direct-pi": "bash scripts/verify-smart-paste-direct-pi.sh",
		"verify:smart-paste:tmux-shell": "bash scripts/verify-smart-paste-tmux-shell.sh",
		"verify:smart-paste:tmux-nvim": "bash scripts/verify-smart-paste-tmux-nvim.sh",
		"verify:smart-paste:tmux-pi": "bash scripts/verify-smart-paste-tmux-pi.sh",
		"verify:tmux:chat-image-preview": "bash scripts/verify-chat-image-preview-tmux-pi.sh",
		"verify:smart-paste:router": "node scripts/verify-wezterm-route-only.mjs",
		"verify:smart-paste:matrix": "node scripts/verify-smart-paste-matrix.mjs"
	},
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"peerDependencies": {
		"@mariozechner/pi-ai": "*",
		"@mariozechner/pi-coding-agent": "*",
		"@mariozechner/pi-tui": "*"
	},
	"optionalDependencies": {
		"@mariozechner/clipboard": "^0.3.3",
		"@silvia-odwyer/photon-node": "^0.3.4"
	},
	"devDependencies": {
		"@mariozechner/pi-ai": "^0.68.1",
		"@mariozechner/pi-coding-agent": "^0.68.1",
		"@mariozechner/pi-tui": "^0.68.1",
		"@types/node": "^25.2.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
